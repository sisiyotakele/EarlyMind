# API Service — copy to .env.local and fill in real values
# See root .env.example for shared values

NODE_ENV=development
PORT=3001

# PostgreSQL — local dev (use docker-compose)
DATABASE_URL=postgresql://earlymind:changeme@localhost:5432/earlymind_dev
DATABASE_URL_TEST=postgresql://earlymind:changeme@localhost:5432/earlymind_test

# Session signing — AUTH-NFR-001: >=128-bit entropy
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
SESSION_EXPIRY_DAYS=7

# PIN lockout config — AUTH-FR-002
PIN_MAX_ATTEMPTS=3
PIN_LOCKOUT_MINUTES=15

# OTP config — AUTH-FR-001
OTP_EXPIRY_SECONDS=300
OTP_MAX_RESENDS_PER_HOUR=3

# SMS Gateway — CON-TECH-003
SMS_GATEWAY_URL=https://api.smsgateway.example/v1/send
SMS_GATEWAY_API_KEY=CHANGE_ME

# Google Gemini — SRS §2.4.5 (report generation)
GEMINI_API_KEY=CHANGE_ME

# AWS — for S3 report/model storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_REPORTS=earlymind-reports
S3_BUCKET_MODELS=earlymind-models

# ML Service — SRS §9.3 (VPC-internal; external only in dev)
ML_SERVICE_URL=http://localhost:8000

# CORS — allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Sentry (optional in dev)
SENTRY_DSN=
