# Root — copy to .env and fill in real values before running
# Do NOT commit .env files to version control

# ─── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database (shared by API and migrations) ──────────────────────────────────
DATABASE_URL=postgresql://earlymind:changeme@localhost:5432/earlymind_dev
DATABASE_URL_TEST=postgresql://earlymind:changeme@localhost:5432/earlymind_test

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 128-bit+ random secret for JWT/session signing — generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ─── SMS OTP Gateway ──────────────────────────────────────────────────────────
SMS_GATEWAY_URL=https://api.smsgateway.example/v1/send
SMS_GATEWAY_API_KEY=CHANGE_ME

# ─── Google Gemini (report generation) ───────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_REPORTS=earlymind-reports
S3_BUCKET_MODELS=earlymind-models
S3_BUCKET_STATIC=earlymind-static

# ─── ML Service (internal) ────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ─── Federated Learning (Flower) ──────────────────────────────────────────────
FLOWER_SERVER_HOST=localhost
FLOWER_SERVER_PORT=9091

# ─── Sentry (error tracking — optional in dev) ────────────────────────────────
SENTRY_DSN=
